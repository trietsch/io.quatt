                "label": {
                  "en": "Cooling",
                  "nl": "Koelen"
                }
              },
              {
                "id": "HEATING",
                "label": {
                  "en": "Heating",
                  "nl": "Verwarmen"
                }
              }
            ]
          }
        ]
      }