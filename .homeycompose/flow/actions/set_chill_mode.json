{
        "title": {
          "en": "Set Chill mode",
          "nl": "Zet Chill modus"
        },
        "titleFormatted": {
          "en": "Set mode to [[mode]]",
          "nl": "Zet modus op [[mode]]"
        },
        "hint": {
          "en": "Set the mode of this Quatt Chill device.",
          "nl": "Zet de modus van dit Quatt Chill-device."
        },
